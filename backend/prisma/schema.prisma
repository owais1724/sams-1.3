generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agency {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  address      String?
  phone        String?
  email        String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  attendances  Attendance[]
  auditLogs    AuditLog[]
  clients      Client[]
  designations Designation[]
  employees    Employee[]
  leaves       Leave[]
  payrolls     Payroll[]
  projects     Project[]
  roles             Role[]
  shifts            Shift[]
  shiftAssignments  ShiftAssignment[]
  users             User[]
  visitors          Visitor[]
  deployments       Deployment[]
  deploymentGuards  DeploymentGuard[]
  incidents         Incident[]

  @@index([slug])
}

model User {
  id          String     @id @default(cuid())
  email       String     @unique
  password    String
  fullName    String
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  agencyId    String?
  roleId      String?
  employeeId  String?    @unique
  phoneNumber String?
  auditLogs        AuditLog[]
  agency           Agency?           @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  employee         Employee?         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  role             Role?             @relation(fields: [roleId], references: [id], onDelete: SetNull)
  deploymentGuards DeploymentGuard[]
  incidents        Incident[]

  @@index([agencyId])
}

model Role {
  id          String       @id @default(cuid())
  name        String
  description String?
  isSystem    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  agencyId    String?
  agency      Agency?      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  users       User[]
  permissions Permission[] @relation("PermissionToRole")

  @@index([agencyId])
}

model Permission {
  id          String   @id @default(cuid())
  action      String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  roles       Role[]   @relation("PermissionToRole")
}

model Client {
  id        String    @id @default(cuid())
  name      String
  contact   String?
  email     String?
  address   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  agencyId  String
  agency      Agency       @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  projects    Project[]
  deployments Deployment[]

  @@index([agencyId])
}

model Project {
  id                String       @id @default(cuid())
  name              String
  location          String?
  description       String?
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  agencyId          String
  clientId          String
  attendances       Attendance[]
  checkpoints       Checkpoint[]
  agency            Agency            @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client            Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignedEmployees Employee[]        @relation("EmployeeToProject")
  shiftAssignments  ShiftAssignment[]

  @@index([agencyId])
}

model Designation {
  id          String     @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  agencyId    String
  agency      Agency     @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  employees   Employee[]

  @@index([agencyId])
}

model Employee {
  id               String       @id @default(cuid())
  email            String?
  address          String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  agencyId         String
  designationId    String?
  employeeCode     String
  fullName         String
  phoneNumber      String?
  status           String       @default("ACTIVE")
  basicSalary      Float        @default(0)
  salaryCurrency   String       @default("USD")
  attendances      Attendance[]
  agency           Agency       @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  designation      Designation? @relation(fields: [designationId], references: [id], onDelete: SetNull)
  leaves           Leave[]
  payrolls         Payroll[]
  shiftAssignments ShiftAssignment[]
  user             User?
  assignedProjects Project[]    @relation("EmployeeToProject")

  @@unique([agencyId, employeeCode])
  @@index([agencyId])
}

model Checkpoint {
  id        String   @id @default(cuid())
  name      String
  latitude  Float?
  longitude Float?
  qrCode    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Attendance {
  id           String      @id @default(cuid())
  date         DateTime
  checkIn      DateTime?
  checkOut     DateTime?
  status       String
  method       String?
  photo        String?
  latitude     Float?
  longitude    Float?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  agencyId     String
  employeeId   String
  projectId    String?
  deploymentId String?
  agency       Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  employee     Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  project      Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deployment   Deployment? @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([date])
  @@index([employeeId])
  @@index([deploymentId])
}

model Payroll {
  id            String    @id @default(cuid())
  month         String
  basicSalary   Float
  allowances    Float     @default(0)
  deductions    Float     @default(0)
  netPay        Float
  status        String    @default("DRAFT")
  generatedDate DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  agencyId      String
  employeeId    String?
  currency      String    @default("USD")
  agency        Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  employee      Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([month])
}

model Visitor {
  id           String    @id @default(cuid())
  name         String
  phone        String?
  purpose      String?
  checkInTime  DateTime  @default(now())
  checkOutTime DateTime?
  vehicleNo    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  agencyId     String
  agency       Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId])
}

model Leave {
  id                   String    @id @default(cuid())
  startDate            DateTime
  endDate              DateTime
  reason               String
  status               String    @default("PENDING")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  agencyId             String
  employeeId           String
  agencyApprovedAt     DateTime?
  agencyApprovedBy     String?
  appliedAt            DateTime  @default(now())
  hrApprovedAt         DateTime?
  hrApprovedBy         String?
  leaveType            String
  rejectionReason      String?
  supervisorApprovedAt DateTime?
  supervisorApprovedBy String?
  agency               Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  employee             Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([employeeId])
}

model Shift {
  id        String            @id @default(cuid())
  name      String
  startTime String            // e.g. "08:00"
  endTime   String            // e.g. "16:00"
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  agencyId  String
  agency      Agency            @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  assignments ShiftAssignment[]
  deployments Deployment[]

  @@index([agencyId])
}

model ShiftAssignment {
  id         String   @id @default(cuid())
  date       DateTime
  status     String   @default("SCHEDULED") // SCHEDULED, COMPLETED, LATE, MISSED
  checkIn    DateTime?
  checkOut   DateTime?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  agencyId   String
  shiftId    String
  employeeId String
  projectId  String?
  agency     Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  shift      Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  project    Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([date])
  @@index([employeeId])
  @@index([shiftId])
}

model Deployment {
  id        String            @id @default(cuid())
  agencyId  String
  clientId  String
  shiftId   String
  startDate DateTime
  endDate   DateTime
  status    String            @default("planned") // planned, active, completed, cancelled
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  agency    Agency            @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client    Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  shift     Shift             @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  guards     DeploymentGuard[]
  incidents  Incident[]
  attendance Attendance[]

  @@index([agencyId])
  @@index([clientId])
  @@index([status])
}

model DeploymentGuard {
  id           String     @id @default(cuid())
  deploymentId String
  userId       String
  agencyId     String
  createdAt    DateTime   @default(now())
  deployment   Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  agency       Agency     @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@unique([deploymentId, userId])
  @@index([agencyId])
  @@index([userId])
}

model Incident {
  id           String     @id @default(cuid())
  agencyId     String
  deploymentId String?
  reportedBy   String
  title        String
  description  String?
  type         String?    // e.g. "theft", "trespassing", "medical", "fire", "vandalism", "other"
  severity     Int        @default(1) // 1=low, 2=medium, 3=high, 4=critical
  status       String     @default("open") // open, under_review, resolved, closed
  reviewNotes  String?    // Supervisor review notes
  resolution   String?    // Admin final remarks
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  agency       Agency     @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  deployment   Deployment? @relation(fields: [deploymentId], references: [id], onDelete: SetNull)
  reporter     User       @relation(fields: [reportedBy], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([status])
  @@index([reportedBy])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String?
  entityId  String?
  details   String?
  metadata  Json?
  severity  String   @default("INFO")
  createdAt DateTime @default(now())
  agencyId  String?
  userId    String?
  agency    Agency?  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([agencyId])
  @@index([userId])
}
